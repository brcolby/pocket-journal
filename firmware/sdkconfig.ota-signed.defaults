# Opt-in overlay for validating the IDF signed-update chain. Combine this with
# an untracked fragment that sets SECURE_BOOT_SIGNING_KEY and the Pocket Journal
# manifest public key. The ordinary sdkconfig.defaults build remains fail-closed.
CONFIG_SECURE_SIGNED_APPS_NO_SECURE_BOOT=y
CONFIG_SECURE_SIGNED_ON_UPDATE_NO_SECURE_BOOT=y
CONFIG_SECURE_SIGNED_APPS_RSA_SCHEME=y
CONFIG_SECURE_BOOT_BUILD_SIGNED_BINARIES=y
